# The Synthetic Firm local environment template.
# Copy values into .env and replace placeholders manually.
# Do not commit real keys, tokens, or signing secrets.

# Local TSF state. Keep this outside the repository for normal use.
TSF_HOME="$HOME/.synthetic-firm"

# Logging
TSF_LOG_LEVEL="INFO"

# Model provider: Kimi Code.
# TSF copies this to KIMI_API_KEY only for the child provider process.
TSF_KIMI_API_KEY="paste_kimi_key_here"
TSF_KIMI_BASE_URL="https://api.kimi.com/coding"

# Optional native provider variable. Prefer TSF_KIMI_API_KEY unless you know you need this.
KIMI_API_KEY=""
KIMI_BASE_URL=""

# Approval signing. Use a long random value for real approvals.
# Example generator: python -c "import secrets; print(secrets.token_urlsafe(48))"
TSF_APPROVAL_SIGNING_SECRET="paste_long_random_signing_secret_here"

# Telegram Control Room. Disabled and dry-run by default.
TSF_TELEGRAM_ENABLED="false"
TSF_TELEGRAM_MODE="dry_run"
TSF_TELEGRAM_BOT_TOKEN="paste_telegram_bot_token_here"
TSF_TELEGRAM_ALLOWED_CHAT_IDS="paste_allowed_chat_id_here"

# Optional config path overrides.
TSF_WORKDAY_CONFIG="agents/workday.yaml"
TSF_POLICY_PATH="agents/policy.yaml"

# Optional compatibility/runtime override. Usually leave blank.
TSF_UPSTREAM_CLI=""
